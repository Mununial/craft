# Environment Variables for Production Deployment

# The port your server will run on (Usually overridden by Render/Railway environments automatically)
PORT=5001

# The MongoDB Atlas connection string (or Firebase equivalents if scaling up)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/kalasutra_production?retryWrites=true&w=majority

# For JWT Authentication processing
JWT_SECRET=super_secret_production_key_here

# For Payment Processing
STRIPE_SECRET_KEY=sk_live_123456789...
